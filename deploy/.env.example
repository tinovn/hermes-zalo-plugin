# ───────────────────────────────────────────────────────────────────────
# CSKH Tino — biến môi trường cho bộ cài Chatwoot + zca-bridge + Hermes plugin
# Copy thành deploy/.env rồi điền. install-all.sh sẽ nạp file này.
# ───────────────────────────────────────────────────────────────────────

# Domain trỏ về VPS 103.142.25.24 (A record). Caddy auto-TLS dùng cái này.
DOMAIN=chat.tino.example

# Email cho Let's Encrypt (Caddy).
ACME_EMAIL=admin@tino.example

# ── Chatwoot ────────────────────────────────────────────────────────────
CHATWOOT_VERSION=master
# Để trống = script tự sinh bằng openssl rand -hex 64
CHATWOOT_SECRET_KEY_BASE=
CHATWOOT_POSTGRES_PASSWORD=
# Tài khoản super admin tạo lần đầu
CHATWOOT_ADMIN_NAME=Tino Admin
CHATWOOT_ADMIN_EMAIL=admin@tino.example
CHATWOOT_ADMIN_PASSWORD=

# ── zca-bridge ──────────────────────────────────────────────────────────
ZCA_BRIDGE_REPO=https://github.com/tinovn/zca-bridge
ZCA_BRIDGE_DIR=/opt/zca-bridge
# Postgres RIÊNG cho bridge (tách DB Chatwoot)
ZCA_DB_NAME=zca
ZCA_DB_USER=zca
ZCA_DB_PASSWORD=
# Để trống = tự sinh bằng openssl
ZCA_CREDENTIALS_KEY=
ZCA_ADMIN_TOKEN=
ZCA_WEBHOOK_SECRET=
ZCA_BRIDGE_PORT=4000
# (Tùy chọn) proxy dân cư cùng quốc gia với số Zalo để giảm rủi ro khoá
ZCA_PROXY=

# Token Chatwoot Application API (tạo trong Chatwoot: Profile -> Access Token).
# Điền sau khi Chatwoot chạy + tạo admin. Dùng chung cho bridge và plugin.
CHATWOOT_API_ACCESS_TOKEN=
CHATWOOT_ACCOUNT_ID=1

# ── Hermes plugin chatwoot ──────────────────────────────────────────────
HERMES_PLUGINS_DIR=/root/.hermes/plugins
CHATWOOT_PLUGIN_HOST=127.0.0.1
CHATWOOT_PLUGIN_PORT=8088
CHATWOOT_MUTE_LABEL=mute-ai
CHATWOOT_BOT_REPLY_STATUSES=pending
CHATWOOT_ALLOW_ALL_USERS=true
# Webhook secret Chatwoot Agent Bot gửi kèm (X-Chatwoot-Webhook-Token).
# Để trống nếu bind loopback. Tự sinh nếu rỗng.
CHATWOOT_WEBHOOK_SECRET=
