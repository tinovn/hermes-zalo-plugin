# ───────────────────────────────────────────────────────────────────────
# Plugin Zalo cá nhân cho Hermes — biến môi trường mẫu
# Copy file này thành .env (hoặc khai báo trong cấu hình Hermes) rồi điền.
# ───────────────────────────────────────────────────────────────────────

# BẮT BUỘC: Zalo UID của chủ tài khoản (người điều khiển bot).
# Lấy UID bằng cách nhắn bot 1 tin rồi xem log, hoặc dùng công cụ tra UID.
ZALO_PERSONAL_OWNER_UID=

# (Tùy chọn) UID Zalo khác cũng được phép chat — phẩy ngăn cách.
ZALO_PERSONAL_ALLOWED_USERS=

# (Tùy chọn) Port sidecar Node.js. Mặc định 3838.
ZALO_PERSONAL_SIDECAR_PORT=3838

# (KHUYẾN NGHỊ) Proxy cho sidecar — nên là proxy DÂN CƯ cùng quốc gia với
# số Zalo để giảm rủi ro khoá. Bỏ trống = đi thẳng IP máy chủ.
#   http://user:pass@host:port   hoặc   socks5://user:pass@host:port
ZALO_PERSONAL_PROXY=

# (Tùy chọn) Thư mục lưu session + dữ liệu marketing. Mặc định /opt/data/zalo.
ZALO_PERSONAL_SESSION_DIR=

# (Tùy chọn) Cách bot xưng hô với chủ. Mặc định "sếp".
ZALO_OWNER_NICKNAME=sếp

# (Tùy chọn) Tên thật của chủ cần CHE nếu bot lỡ nhắc. Bỏ trống = không che.
ZALO_OWNER_NAME=

# (Tùy chọn) Đường dẫn google_token.json (OAuth Google CỦA BẠN) để bật xuất
# Google Sheet trong phễu marketing. Bỏ trống = phễu vẫn chạy, chỉ không
# tạo Google Sheet.
GOOGLE_TOKEN_PATH=

# (Tùy chọn) Thread/chat ID mặc định để cron/notification đẩy về.
ZALO_PERSONAL_HOME_THREAD=
